# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Environment / secrets
.env

# Downloaded media (configured via QBIT_DOWNLOAD_PATH)
Downloads/
.offline_cache/
.ondemand_cache/
.background/

# Ephemeral share clips (auto-purged after 2h; see /api/library/{id}/clip)
.clips/

# Permanent on-disk cache of TMDb artwork (served via /api/metadata/img)
.tmdb_img_cache/

# User library database (profiles + watch history)
library.json

# iOS client app pairing tokens (M5) — secrets, host-local
device_tokens.json

# Runtime scratch: countdown text VLC reads for the on-TV skip popup
.vlc_marquee.txt

# Runtime scratch: one-shot elevated powercfg script (Windows power buttons)
_powercfg_apply.bat

# Dedicated Chrome profile for the YouTube-on-TV kiosk window
.tv_chrome_profile/

# macOS
.DS_Store
._*

# IDEs
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
uvicorn*.log

# Portable Smart Skip binaries downloaded by setup.py
tools/


streamlink_service.py