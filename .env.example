# ── Jackett (P2P Indexer) ─────────────────────────────────────────────────────
# Jackett Web UI → API Key (top-right corner after logging in)
INDEXER_URL=http://localhost:9117
INDEXER_API_KEY=your_jackett_api_key_here
# 0=all categories | 2000=Movies | 5000=TV | 3000=Audio
INDEXER_CATEGORIES=0

# ── qBittorrent ───────────────────────────────────────────────────────────────
# Tools → Preferences → Web UI  (set port to 8081 to avoid VLC conflict)
QBIT_URL=http://localhost:8081
QBIT_USERNAME=admin
QBIT_PASSWORD=adminadmin
# Absolute path where torrents will be saved (created automatically)
QBIT_DOWNLOAD_PATH=/Users/yourname/Downloads/StreamLink

# ── VLC ───────────────────────────────────────────────────────────────────────
# VLC → Preferences → Show All → Interface → Main interfaces → check "Web"
# Set Lua HTTP password under Interface → Main interfaces → Lua
# Port stays at 8080 (VLC default)
VLC_URL=http://localhost:8080
VLC_PASSWORD=vlcpassword

# ── Buffer thresholds ─────────────────────────────────────────────────────────
# Stream to VLC once either threshold is crossed (whichever comes first)
BUFFER_MIN_MB=15.0
BUFFER_MIN_PCT=1.0

# ── Wireless remote (air-mouse) + TV UI ───────────────────────────────────────
# Input listener for HID wireless remotes plugged into this host
# (play/pause, volume, skip, Home). 1 = on (default), 0 = off. See docs/REMOTE.md
REMOTE_CONTROL=1
# Firestick-style dashboard kiosk on the TV: any remote button wakes the web UI,
# idle hands the screen back to the background video, Home stops playback and
# opens it. Needs REMOTE_CONTROL=1 for the wake signal.
TV_UI=1
TV_UI_IDLE_SECS=120
# Advanced: OS-mixer volume watchdog. Leave 0 unless the remote's volume keys
# change the WINDOWS system volume even while StreamLink is running (a remote
# whose volume bypasses the keyboard hook). See docs/REMOTE.md.
REMOTE_VOLUME_GUARD=0
