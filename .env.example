# ── Jackett (P2P Indexer) ─────────────────────────────────────────────────────
# Jackett Web UI → API Key (top-right corner after logging in)
INDEXER_URL=http://localhost:9117
INDEXER_API_KEY=your_jackett_api_key_here
# 0=all categories | 2000=Movies | 5000=TV | 3000=Audio
INDEXER_CATEGORIES=0

# ── qBittorrent ───────────────────────────────────────────────────────────────
# Tools → Preferences → Web UI  (set port to 8081 to avoid VLC conflict)
QBIT_URL=http://localhost:8081
QBIT_USERNAME=admin
QBIT_PASSWORD=adminadmin
# Absolute path where torrents will be saved (created automatically)
QBIT_DOWNLOAD_PATH=/Users/yourname/Downloads/StreamLink

# ── VLC ───────────────────────────────────────────────────────────────────────
# VLC → Preferences → Show All → Interface → Main interfaces → check "Web"
# Set Lua HTTP password under Interface → Main interfaces → Lua
# Port stays at 8080 (VLC default)
VLC_URL=http://localhost:8080
VLC_PASSWORD=vlcpassword

# ── Buffer thresholds ─────────────────────────────────────────────────────────
# Stream to VLC once either threshold is crossed (whichever comes first)
BUFFER_MIN_MB=15.0
BUFFER_MIN_PCT=1.0
